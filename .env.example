# Copy this file to .env on the production server and fill in the values.
# Never commit .env to the repository.

DEV_MODE=false

JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
GOOGLE_API_KEY=your_google_generative_ai_api_key
CORS_ORIGIN=https://descartes-square.bishko.site
MONGO_USER=admin
MONGO_PASSWORD=replace_with_strong_password
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

GOOGLE_CLIENT_ID=goolge_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Session (used only for OAuth state CSRF, not user sessions)
SESSION_SECRET=replace_with_strong_secret

# Frontend URL (for OAuth redirect after callback)
FRONTEND_URL=http://localhost:4200

# Brevo SMTP (for email verification)
BREVO_SMTP_LOGIN=your_brevo_smtp_login@example.com
BREVO_SMTP_KEY=your_brevo_smtp_key

# Sender address — must be an authorized sender in Brevo (Settings → Senders)
MAIL_FROM="Descartes Square" <no-reply@domain.com>
